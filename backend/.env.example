FORGE_ENV=development
DATABASE_URL=sqlite:///./forge.db

# OpenAI — for AI Coach narration and goal polish
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS — add your frontend URL
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Garmin Connect credentials (server-side only, never sent to browser)
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Your birth year for Fitness Age / Biological Age
USER_BIRTH_YEAR=1990

# Wake window for Day Progress Ring
FORGE_WAKE_HOUR=8
FORGE_SLEEP_HOUR=24
