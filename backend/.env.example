FORGE_ENV=development
DATABASE_URL=sqlite:///./forge.db

# OpenAI — for AI Coach narration and goal polish
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS — add your frontend URL
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Encrypts per-user Garmin session tokens. Required in production.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FORGE_CONNECTION_ENCRYPTION_KEY=

# Forge user age, height, and Garmin credentials are entered in the app and
# stored per account. Do not place GARMIN_EMAIL or GARMIN_PASSWORD in this file.

# Wake window for Day Progress Ring
FORGE_WAKE_HOUR=8
FORGE_SLEEP_HOUR=24
